#!/usr/bin/env bash
#
# Pre-commit hook: run an agent to review staged changes and update
# CHANGELOG.md (and README.md when needed), then re-stage them into the
# in-flight commit.
#
# Controls:
#   SKIP_CHANGELOG_HOOK=1    Bypass the hook for a single commit.
#   CHANGELOG_AGENT_CMD=...  Override the agent command (default: declawd).
#                            The command is invoked as: $CMD -p "<prompt>"
#
# You can also bypass with `git commit --no-verify`.

set -euo pipefail

if [[ "${SKIP_CHANGELOG_HOOK:-}" == "1" ]]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged="$(git diff --cached --name-only)"
if [[ -z "$staged" ]]; then
  exit 0
fi

# Skip if the staged set is only CHANGELOG.md and/or README.md — lets you
# hand-edit them without triggering the agent, and avoids any self-loop.
non_doc_staged="$(printf '%s\n' "$staged" | grep -vE '^(CHANGELOG\.md|README\.md)$' || true)"
if [[ -z "$non_doc_staged" ]]; then
  exit 0
fi

AGENT_CMD="${CHANGELOG_AGENT_CMD:-declawd}"
agent_bin="${AGENT_CMD%% *}"

if ! command -v "$agent_bin" >/dev/null 2>&1; then
  echo "pre-commit: '$agent_bin' not on PATH — skipping changelog update." >&2
  exit 0
fi

echo "pre-commit: running '$AGENT_CMD' to review staged changes and update CHANGELOG/README..."

prompt='Review the staged changes in this commit (use `git diff --cached` and `git diff --cached --stat` to inspect them) and update CHANGELOG.md with a new entry describing what changed. Follow the existing CHANGELOG style: newest first, grouped under a `## YYYY-MM-DD` heading for today. If today already has a heading, append to it. If user-facing setup steps, commands, architecture, or tool integrations documented in README.md have changed, update README.md as well. Only modify CHANGELOG.md and README.md — do not touch any other files, do not run git commands that mutate state, and do not create a commit.'

# shellcheck disable=SC2086
$AGENT_CMD -p "$prompt"

restaged=0
for f in CHANGELOG.md README.md; do
  if [[ -f "$f" ]] && ! git diff --quiet -- "$f"; then
    git add "$f"
    echo "pre-commit: staged updated $f"
    restaged=1
  fi
done

if [[ "$restaged" -eq 0 ]]; then
  echo "pre-commit: agent made no changes to CHANGELOG/README."
fi

exit 0
