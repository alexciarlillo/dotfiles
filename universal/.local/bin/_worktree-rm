#!/usr/bin/env bash
set -euo pipefail

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
CLEAR="\033[0m"

die() {
  printf '%b%s%b\n' "$RED" "$1" "$CLEAR" >&2
  exit 1
}

warn() {
  printf '%b%s%b\n' "$YELLOW" "$1" "$CLEAR" >&2
}

info() {
  printf '%s\n' "$1" >&2
}

success() {
  printf '%b%s%b\n' "$GREEN" "$1" "$CLEAR" >&2
}

usage() {
  cat <<EOF
This is meant to be called from the 'worktree-rm' wrapper function, not directly.

Usage: _worktree-rm [-f] <branch-or-directory-name>

Remove a git worktree and its local branch in a bare repo setup (created by clone-for-wt).

Must be run from the repo root directory containing .bare/ and .git file.

Options:
  -f    Force removal (even if worktree has uncommitted changes)

The script will:
  1. Resolve the worktree directory (converting slashes to dashes, like _worktree does)
  2. Remove the worktree via git
  3. Delete the local branch if it's not the primary branch

Examples:
  _worktree-rm feature/new-ui    # removes ./feature-new-ui/
  _worktree-rm feature-new-ui    # same thing
  _worktree-rm -f bugfix-123     # force remove even with uncommitted changes
EOF
  exit 1
}

FORCE=false
while getopts "fh" opt; do
  case $opt in
    f) FORCE=true ;;
    h) usage ;;
    *) usage ;;
  esac
done
shift $((OPTIND - 1))

if [ $# -eq 0 ]; then
  usage
fi

INPUT="$1"

if [ ! -d ".bare" ] || [ ! -f ".git" ]; then
  die "Not in a bare repo worktree root (expected .bare/ directory and .git file). Run this from the repo root created by clone-for-wt."
fi

WORKTREE_DIR="${INPUT//\//-}"

if [ ! -d "$WORKTREE_DIR" ]; then
  die "Worktree directory not found: $WORKTREE_DIR"
fi

BRANCH_NAME=$(git -C "$WORKTREE_DIR" rev-parse --abbrev-ref HEAD 2>/dev/null) || true

if [ "$FORCE" = true ]; then
  info "Force removing worktree: $WORKTREE_DIR"
  git worktree remove --force "$WORKTREE_DIR" >&2
else
  info "Removing worktree: $WORKTREE_DIR"
  git worktree remove "$WORKTREE_DIR" >&2
fi

if [ -n "$BRANCH_NAME" ] && [ "$BRANCH_NAME" != "master" ] && [ "$BRANCH_NAME" != "main" ]; then
  info "Deleting local branch: $BRANCH_NAME"
  if [ "$FORCE" = true ]; then
    git branch -D "$BRANCH_NAME" >&2 2>/dev/null || warn "Branch '$BRANCH_NAME' already gone or could not be deleted"
  else
    git branch -d "$BRANCH_NAME" >&2 2>/dev/null || warn "Branch '$BRANCH_NAME' not fully merged; use -f to force delete"
  fi
fi

success "Worktree removed: $WORKTREE_DIR"
