#!/usr/bin/env bash
set -euo pipefail

RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
CLEAR="\033[0m"

die() {
  printf '%b%s%b\n' "$RED" "$1" "$CLEAR" >&2
  exit 1
}

warn() {
  printf '%b%s%b\n' "$YELLOW" "$1" "$CLEAR" >&2
}

info() {
  printf '%s\n' "$1" >&2
}

success() {
  printf '%b%s%b\n' "$GREEN" "$1" "$CLEAR" >&2
}

get_primary_branch() {
  if git show-ref --verify --quiet refs/remotes/origin/master; then
    echo "master"
  elif git show-ref --verify --quiet refs/remotes/origin/main; then
    echo "main"
  else
    die "Could not determine primary branch (no origin/master or origin/main)"
  fi
}

usage() {
  cat <<EOF
This is meant to be called from the 'worktree' wrapper script, not directly.

Usage: _worktree <branch-name>

Add a git worktree for the given branch in a bare repo setup (created by clone-for-wt).

Must be run from the repo root directory containing .bare/ and .git file.

The script will:
  1. Fetch the latest refs from origin
  2. If the branch exists on origin, check it out as a tracking worktree
  3. If it doesn't exist, create a new local branch based on the primary branch

Examples:
  _worktree feature/new-ui    # creates ./feature-new-ui/
  _worktree bugfix-123        # creates ./bugfix-123/
EOF
  exit 1
}

if [ $# -eq 0 ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
  usage
fi

BRANCH_NAME="$1"

# Validate we're in a bare repo worktree root (has .bare dir and .git file)
if [ ! -d ".bare" ] || [ ! -f ".git" ]; then
  die "Not in a bare repo worktree root (expected .bare/ directory and .git file). Run this from the repo root created by clone-for-wt."
fi

is_roblox_repo() {
  git remote get-url origin 2>/dev/null | grep -qiE "roblox|rbx"
}

run_post_create_hooks() {
  local worktree_dir="$1"
  local branch_name="$2"
  local repo_root
  repo_root="$(pwd)"

  local -a hook_dirs=(
    ".worktree-hooks/post-create.d"
    "${XDG_CONFIG_HOME:-$HOME/.config}/worktree/hooks.d/post-create.d"
  )

  for dir in "${hook_dirs[@]}"; do
    [ -d "$dir" ] || continue
    for hook in "$dir"/*; do
      [ -x "$hook" ] || continue
      info "Running post-create hook: $hook"
      WORKTREE_DIR="$repo_root/$worktree_dir" \
        BRANCH_NAME="$branch_name" \
        BARE_DIR="$repo_root/.bare" \
        REPO_ROOT="$repo_root" \
        PRIMARY_BRANCH="$(get_primary_branch)" \
        "$hook" >&2 || warn "Hook failed: $hook (continuing)"
    done
  done
}

WORKTREE_DIR="${BRANCH_NAME//\//-}"

if [ -d "$WORKTREE_DIR" ]; then
  warn "Worktree directory already exists: $WORKTREE_DIR"
  echo "$WORKTREE_DIR"
  exit 0
fi

info "Fetching from origin..."
git fetch origin >&2

# For Roblox repos, also check for the prefixed branch on origin
PREFIXED_BRANCH=""
if [ -n "${RBX_GITHUB_USER:-}" ] && is_roblox_repo && [[ "$BRANCH_NAME" != "$RBX_GITHUB_USER/"* ]]; then
  PREFIXED_BRANCH="$RBX_GITHUB_USER/$BRANCH_NAME"
fi

if git show-ref --verify --quiet "refs/remotes/origin/$BRANCH_NAME"; then
  info "Branch '$BRANCH_NAME' found on origin, checking out..."
  git worktree add "$WORKTREE_DIR" "$BRANCH_NAME" >&2
elif [ -n "$PREFIXED_BRANCH" ] && git show-ref --verify --quiet "refs/remotes/origin/$PREFIXED_BRANCH"; then
  info "Branch '$PREFIXED_BRANCH' found on origin, checking out..."
  git worktree add "$WORKTREE_DIR" "$PREFIXED_BRANCH" >&2
else
  # For new branches in Roblox repos, prepend RBX_GITHUB_USER to the branch name
  if [ -n "${RBX_GITHUB_USER:-}" ] && is_roblox_repo; then
    if [[ "$BRANCH_NAME" != "$RBX_GITHUB_USER/"* ]]; then
      BRANCH_NAME="$RBX_GITHUB_USER/$BRANCH_NAME"
      info "Roblox repo detected, prefixing branch: $BRANCH_NAME"
    fi
  fi

  PRIMARY=$(get_primary_branch)
  info "Branch '$BRANCH_NAME' not found on origin, creating from $PRIMARY..."
  git worktree add --no-track -b "$BRANCH_NAME" "$WORKTREE_DIR" "origin/$PRIMARY" >&2
  git -C "$WORKTREE_DIR" config "branch.$BRANCH_NAME.remote" origin >&2
  git -C "$WORKTREE_DIR" config "branch.$BRANCH_NAME.merge" "refs/heads/$BRANCH_NAME" >&2
fi

run_post_create_hooks "$WORKTREE_DIR" "$BRANCH_NAME"

success "Worktree ready: $WORKTREE_DIR"
echo "$WORKTREE_DIR"
