# Start the session setup
twork-init() {
  tmux new-session -d -s edit -n home # Edit session (neovim, etc.)
  tmux new-session -d -s agent -n home # agent session (agents)
  tmux new-session -d -s adhoc -n home # Adhoc session (misc tasks)
  # Switching windows in edit also switches in agent & adhoc.
  # run-shell expands #{window_name} before the shell runs; select-window -t
  # does not expand formats in its target. Missing windows are silently ignored.
  tmux set-hook -t edit after-select-window \
    'run-shell "tmux select-window -t agent:#{window_name} 2>/dev/null; tmux select-window -t adhoc:#{window_name} 2>/dev/null"'
  # Clear the "?" needs-input indicator across paired windows when the user
  # focuses one. Appended (-a) so the edit session keeps its window-sync hook.
  for s in edit agent adhoc; do
    tmux set-hook -at "$s" after-select-window \
      'run-shell "~/.claude/hooks/tmux-clear-indicator.sh"'
  done
}

# Create a new project (paired windows in both sessions)
# Usage: twork-new [<path>]  or  twork-new <name> <path>
twork-new() {
  local name dir
  if [[ -n "$2" ]]; then
    name="$1"
    dir="$2"
  elif [[ -n "$1" ]]; then
    dir="$1"
    name="$(basename "$dir")"
  else
    dir="$(pwd)"
    name="$(basename "$dir")"
  fi
  dir="${dir:a}"
  tmux new-window -t adhoc -n "$name" -c "$dir"
  tmux new-window -t agent -n "$name" -c "$dir"
  tmux new-window -t edit -n "$name" -c "$dir"
}

# Close a project (both windows)
twork-close() {
  local current_session
  current_session="$(tmux display-message -p '#{session_name}')"
  local name="${1:-$(tmux display-message -p '#{window_name}')}"
  # Kill the other session's window first, then our own, so the shell
  # survives long enough to issue both commands.
  if [[ "$current_session" == "edit" ]]; then
    tmux kill-window -t "agent:$name" 2>/dev/null
    tmux kill-window -t "adhoc:$name" 2>/dev/null
    tmux kill-window -t "edit:$name" 2>/dev/null
  elif [[ "$current_session" == "agent" ]]; then
    tmux kill-window -t "edit:$name" 2>/dev/null
    tmux kill-window -t "adhoc:$name" 2>/dev/null
    tmux kill-window -t "agent:$name" 2>/dev/null
  else
    tmux kill-window -t "edit:$name" 2>/dev/null
    tmux kill-window -t "agent:$name" 2>/dev/null
    tmux kill-window -t "adhoc:$name" 2>/dev/null
  fi
}

# List active projects
twork-ls() {
  tmux list-windows -t edit -F '#{window_name}'
}

# Attach to the edit session
twork-edit() {
  tmux attach-session -t edit
}

# Attach to the agent session
twork-agent() {
  tmux attach-session -t agent
} 

# Attach to the adhoc session
twork-adhoc() {
  tmux attach-session -t adhoc
}

# Sync the current pane's working directory to the matching window in the
# paired session (edit <-> agent). Optionally pass a window name; defaults
# to the current window.
twork-sync() {
  local current_session
  current_session="$(tmux display-message -p '#{session_name}')"

  local -a target_sessions
  if [[ "$current_session" == "edit" ]]; then
    target_sessions=(agent adhoc)
  elif [[ "$current_session" == "agent" ]]; then
    target_sessions=(edit adhoc)
  elif [[ "$current_session" == "adhoc" ]]; then
    target_sessions=(edit agent)
  else
    echo "twork-sync: must be run from the edit, agent, or adhoc session" >&2
    return 1
  fi

  local win="${1:-$(tmux display-message -p '#{window_name}')}"
  local dir
  dir="$(tmux display-message -p '#{pane_current_path}')"

  local ts
  for ts in "${target_sessions[@]}"; do
    if tmux select-window -t "$ts:$win" 2>/dev/null; then
      tmux send-keys -t "$ts:$win" "cd ${(q)dir}" Enter
    fi
  done
}
